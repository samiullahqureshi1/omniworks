datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id                   String   @id @default(uuid())
  name                 String
  slug                 String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ownerUserId          String?
  parentOrganizationId String?

  owner              User?          @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  parentOrganization Organization?  @relation("ChildOrganizations", fields: [parentOrganizationId], references: [id])
  childOrganizations Organization[] @relation("ChildOrganizations")

  users           User[]
  invitations     Invitation[]
  projects        Project[]
  tasks           Task[]
  taskStatuses    TaskStatus[]
  projectStatuses ProjectStatus[]
  timeEntries     TimeEntry[]
  activeTimers    ActiveTimer[]
  timeScreenshots TimeScreenshot[]
  activityLogs    ActivityLog[]
  idlePeriods     IdlePeriod[]
  settings        Setting[]
  reports         Report[]
  notifications   Notification[]
  messages        ProjectMessage[]
  userPresences   UserPresence[]
  projectTemplates ProjectTemplate[]
  taskTemplates    TaskTemplate[]
  rules            Rule[]
  chatGroups    ChatGroup[]
  groupMessages GroupMessage[]
  documents        Document[]
}

enum Role {
  OWNER
  MEMBER
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id               String       @id @default(uuid())
  name             String
  email            String
  passwordHash     String
  role             Role
  status           UserStatus   @default(ACTIVE)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  twoFactorSecret  String?
  twoFactorEnabled Boolean      @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  ownedOrganizations    Organization[]       @relation("OrganizationOwner")
  clientProjects        Project[]            @relation("ProjectClient")
  managedProjects       Project[]            @relation("ProjectManager")
  projectAssignees      ProjectAssignee[]
  taskAssignees         TaskAssignee[]
  timeEntries           TimeEntry[]
  activeTimers          ActiveTimer[]
  timeScreenshots       TimeScreenshot[]
  activityLogs          ActivityLog[]
  idlePeriods           IdlePeriod[]
  notificationsReceived Notification[]       @relation("NotificationRecipient")
  notificationsActed    Notification[]       @relation("NotificationActor")
  messagesSent          ProjectMessage[]     @relation("MessageSender")
  messageMentions       MessageMention[]
  messageReadReceipts   MessageReadReceipt[]
  presence              UserPresence?
  ownedChatGroups       ChatGroup[]              @relation("ChatGroupOwner")
  chatGroupMemberships  ChatGroupMember[]
  groupMessagesSent    GroupMessage[]           @relation("GroupMessageSender")
  groupReadReceipts     GroupMessageReadReceipt[]
  documents             Document[]               @relation("DocumentAuthor")

  @@unique([email, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  role           Role
  token          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accepted       Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model ProjectStatus {
  id             String       @id @default(uuid())
  name           String
  color          String       @default("#cccccc")
  order          Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByOwner Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projects Project[]
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Project {
  id                  String         @id @default(uuid())
  name                String
  description         String?
  notes               String?
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId            String?
  client              User?          @relation("ProjectClient", fields: [clientId], references: [id], onDelete: SetNull)
  projectManagerId    String?
  projectManager      User?          @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  statusId            String?
  status              ProjectStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  startDate           DateTime
  endDate             DateTime?
  isOngoing           Boolean        @default(false)
  projectBudget       Float?
  totalAllocatedHours Float?
  priority            Priority       @default(MEDIUM)
  customFields        Json?
  isRepeated          Boolean        @default(false)
  isInternal          Boolean        @default(false)
  department          String?
  team                String?
  repeatTime          String?
  createdAt           DateTime       @default(now())

  // Relations
  assignees       ProjectAssignee[]
  tasks           Task[]
  timeEntries     TimeEntry[]
  activeTimers    ActiveTimer[]
  timeScreenshots TimeScreenshot[]
  notifications   Notification[]
  messages        ProjectMessage[]
  rules           ProjectRule[]
  ruleLogs        RuleLog[]
  documents       Document[]

  @@index([organizationId])
  @@index([clientId])
  @@index([projectManagerId])
  @@index([statusId])
}

model ProjectAssignee {
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model TaskStatus {
  id             String       @id @default(uuid())
  name           String
  color          String       @default("#cccccc")
  order          Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByOwner Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tasks Task[]
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  allocatedHours Float?
  trackedHours   Float?       @default(0)
  dueDate        DateTime?
  statusId       String?
  status         TaskStatus?  @relation(fields: [statusId], references: [id], onDelete: SetNull)
  priority       Priority     @default(MEDIUM)
  customFields   Json?
  isRepeated     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  assignees       TaskAssignee[]
  timeEntries     TimeEntry[]
  activeTimers    ActiveTimer[]
  timeScreenshots TimeScreenshot[]
  notifications   Notification[]
  messageMentions MessageTaskMention[]
  messages        ProjectMessage[]
  documents       Document[]

  @@index([organizationId])
  @@index([projectId])
  @@index([statusId])
}

model TaskAssignee {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

enum TimeEntryType {
  TIMER
  MANUAL
}

enum TimeEntryStatus {
  SAVED
  PENDING
  APPROVED
  REJECTED
}

model TimeEntry {
  id                   String          @id @default(uuid())
  organizationId       String
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId            String
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId               String?
  task                 Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  memberId             String
  member               User            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  startTime            DateTime
  endTime              DateTime?
  duration             Float? // total hours
  activeWorkedDuration Float? // active worked hours
  idleDuration         Float? // idle hours
  entryType            TimeEntryType   @default(TIMER)
  status               TimeEntryStatus @default(SAVED)
  notes                String?
  createdBy            String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  screenshots   TimeScreenshot[]
  activityLogs  ActivityLog[]
  idlePeriods   IdlePeriod[]
  notifications Notification[]

  @@index([organizationId])
  @@index([projectId])
  @@index([taskId])
  @@index([memberId])
}

model ActiveTimer {
  id                   String       @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId            String
  project              Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId               String?
  task                 Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  memberId             String
  member               User         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  startTime            DateTime
  lastActivityAt       DateTime
  idleStartedAt        DateTime?
  isIdle               Boolean      @default(false)
  activeWorkedDuration Float        @default(0) // seconds
  idleDuration         Float        @default(0) // seconds
  notes                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  screenshots  TimeScreenshot[]
  activityLogs ActivityLog[]

  @@unique([memberId])
  @@index([organizationId])
  @@index([projectId])
  @@index([taskId])
}

model TimeScreenshot {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId         String?
  task           Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  memberId       String
  member         User         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  timeEntryId    String?
  timeEntry      TimeEntry?   @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  activeTimerId  String?
  activeTimer    ActiveTimer? @relation(fields: [activeTimerId], references: [id], onDelete: Cascade)
  screenshotUrl  String
  capturedAt     DateTime
  activityLevel  Int          @default(100)
  createdAt      DateTime     @default(now())
}

model ActivityLog {
  id                 String       @id @default(uuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberId           String
  member             User         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  timeEntryId        String?
  timeEntry          TimeEntry?   @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  activeTimerId      String?
  activeTimer        ActiveTimer? @relation(fields: [activeTimerId], references: [id], onDelete: Cascade)
  timestamp          DateTime
  keystrokes         Int          @default(0)
  mouseMovements     Int          @default(0)
  activityPercentage Int          @default(0)
  createdAt          DateTime     @default(now())
}

model IdlePeriod {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberId       String
  member         User         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  timeEntryId    String?
  timeEntry      TimeEntry?   @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  startTime      DateTime
  endTime        DateTime?
  duration       Float? // in seconds
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Setting {
  id             String       @id @default(uuid())
  key            String
  value          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([key, organizationId])
}

model Report {
  id             String       @id @default(uuid())
  name           String
  type           String
  config         String // JSON string for report configuration
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  timeEntryId String?
  timeEntry   TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  actorRole     String?
  recipientRole String?

  type      String
  title     String
  message   String
  isRead    Boolean @default(false)
  actionUrl String?
  metadata  String? // JSON string for additional context

  createdAt DateTime @default(now())
}

enum MessageVisibility {
  PUBLIC
  INTERNAL
}

model ProjectMessage {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId    String?
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content         String
  visibility      MessageVisibility @default(PUBLIC)
  parentMessageId String?
  parentMessage   ProjectMessage?   @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies         ProjectMessage[]  @relation("MessageReplies")
  isEdited        Boolean           @default(false)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  mentions     MessageMention[]
  taskMentions MessageTaskMention[]
  readReceipts MessageReadReceipt[]
}

model MessageMention {
  id              String         @id @default(uuid())
  messageId       String
  message         ProjectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mentionedUserId String
  mentionedUser   User           @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@unique([messageId, mentionedUserId])
}

model MessageTaskMention {
  id        String         @id @default(uuid())
  messageId String
  message   ProjectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([messageId, taskId])
}

model MessageReadReceipt {
  id          String         @id @default(uuid())
  messageId   String
  message     ProjectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime       @default(now())

  @@unique([messageId, userId])
}

model UserPresence {
  userId         String       @id
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         String       @default("OFFLINE")
  lastSeen       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model ProjectTemplate {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  config         Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model TaskTemplate {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  config         Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Rule {
  id               String        @id @default(uuid())
  name             String
  description      String?
  isActive         Boolean       @default(true)
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  frequency        String?       // DAILY, WEEKLY, MONTHLY (Deprecated)
  reminderTime     String?       // e.g. "09:00 AM" (Deprecated)
  triggerField     String?       // Title, Status, Priority, Due Date, Assigned User, Project
  triggerOperator  String?       // Contains, Equals, Starts With, Ends With
  triggerValue     String?       // e.g. "urgent"
  actionType       String        // SEND_REMINDER, CREATE_TASK, UPDATE_STATUS, SEND_NOTIFICATION, In-app Notification, Notification Email
  recipients       Json          // Keep for PM / PM roles
  actionRecipients Json?         // specific user IDs selected in dropdown
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  projects         ProjectRule[]
  logs             RuleLog[]

  @@index([organizationId])
}

model ProjectRule {
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ruleId    String
  rule      Rule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([projectId, ruleId])
}

model RuleLog {
  id          String   @id @default(uuid())
  ruleId      String
  rule        Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  executedAt  DateTime @default(now())
  sentTo      String
  status      String   // SUCCESSFUL, FAILED
  triggerData String?
  error       String?

  @@index([ruleId])
}

model ChatGroup {
  id             String   @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User     @relation("ChatGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  isDirect       Boolean  @default(false)
  status         String   @default("ACTIVE") // can be "PENDING", "ACCEPTED", "DECLINED", "ACTIVE"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members        ChatGroupMember[]
  messages       GroupMessage[]

  @@index([organizationId])
}

model ChatGroupMember {
  id        String    @id @default(uuid())
  groupId   String
  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime  @default(now())

  @@unique([groupId, userId])
}

model GroupMessage {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groupId         String
  group           ChatGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User          @relation("GroupMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content         String
  parentMessageId String?
  parentMessage   GroupMessage? @relation("GroupMessageReplies", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies         GroupMessage[] @relation("GroupMessageReplies")
  fileUrl         String?
  fileName        String?
  fileSize        Float?
  isEdited        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  readReceipts    GroupMessageReadReceipt[]

  @@index([groupId])
  @@index([organizationId])
}

model GroupMessageReadReceipt {
  id        String       @id @default(uuid())
  messageId String
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime     @default(now())

  @@unique([messageId, userId])
}

enum DocumentType {
  DOC
  FILE
}

model Document {
  id             String       @id @default(uuid())
  type           DocumentType @default(DOC)
  title          String
  content        String?
  fileUrl        String?
  fileName       String?
  fileSize       Float?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId         String?
  task           Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?        @relation("DocumentAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([taskId])
}



